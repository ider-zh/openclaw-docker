# OpenClaw bootstrap configuration (example values)
# Set these in your environment or edit this file.

# API key used by openclaw onboard
OPENCLAW_CUSTOM_API_KEY=sk-example
# Base URL for provider
OPENCLAW_CUSTOM_BASE_URL=https://api.toop.ai/v1
# Compatibility mode
OPENCLAW_CUSTOM_COMPATIBILITY=openai
# Default model id
OPENCLAW_CUSTOM_MODEL_ID=mimo-v2.5
# Provider id
OPENCLAW_CUSTOM_PROVIDER_ID=toop
# Gateway settings
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789

# Skip flags (true/false). Defaults mirror previous behavior (true).
OPENCLAW_SKIP_UI=true
# OPENCLAW_SKIP_HEALTH=true
# OPENCLAW_SKIP_CHANNELS=true
# OPENCLAW_SKIP_HOOKS=true
# OPENCLAW_SKIP_SEARCH=true
# OPENCLAW_SKIP_SKILLS=true
# OPENCLAW_SKIP_DAEMON=true
