{
  "meta": {
    "exampleVersion": "v2026.5.12",
    "description": "Version-specific demo config for openclaw/openclaw.json"
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "toop/mimo-v2.5"
      },
      "models": {
        "toop/mimo-v2.5": {}
