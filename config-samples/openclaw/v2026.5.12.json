        "models": [
          {
            "id": "mimo-v2.5",
            "name": "mimo-v2.5 (Custom Provider)",
            "contextWindow": 128000,
            "maxTokens": 14096
          }
        ],
        "request": {
          "allowPrivateNetwork": true
        }
      }
    }
  },
  "plugins": {
